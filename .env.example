# FameHub LMS Environment Variables Template
# Copy this file to .env and fill in the actual production credentials

# Application Config
PORT=5000
NODE_ENV=production
CSRF_ENABLED=true

# Authentication Secrets
JWT_SECRET=replace_with_a_secure_random_hash_at_least_32_characters
JWT_EXPIRES_IN=15m

# Database Configuration
# Primary: PostgreSQL. Example connection string: postgres://user:password@host:port/db_name
DATABASE_URL=postgres://postgres:postgres_password@localhost:5432/famehub

# Fallback: SQLite database file path used if PostgreSQL is unreachable
SQLITE_DB_PATH=./database.sqlite

# Caching Configuration
# Redis instance URL
REDIS_URL=redis://localhost:6379

# Kafka Streaming Configuration
# Comma-separated list of broker endpoints (e.g. host1:port,host2:port)
KAFKA_CLIENT_ID=famehub-lms
KAFKA_BROKERS=localhost:9092

# BigBlueButton virtual classroom endpoint configuration
# Obtain from your BigBlueButton service provider or self-hosted deployment
BBB_URL=https://demo.bigbluebutton.org/bigbluebutton/api
BBB_SECRET=8cd8ef52e85e0007384c3130864d309b

# Attendance System Configuration
# Minimum duration (seconds) a participant must stay in the meeting to be marked Present
ATTENDANCE_THRESHOLD_SECONDS=60
